{
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/route.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/route.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "public": true
}
